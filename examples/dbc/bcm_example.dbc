VAL_ 100 BCM_DoorLockFL 0 "Locked" 1 "Unlocked" ;
VAL_ 100 BCM_DoorLockFR 0 "Locked" 1 "Unlocked" ;
VAL_ 100 BCM_DoorLockRL 0 "Locked" 1 "Unlocked" ;
VAL_ 100 BCM_DoorLockRR 0 "Locked" 1 "Unlocked" ;
VAL_ 100 BCM_TrunkStatus 0 "Closed" 1 "Open" ;
VAL_ 100 BCM_HazardLight 0 "Off" 1 "On" ;
VAL_ 100 BCM_LowBeam 0 "Off" 1 "On" ;
VAL_ 100 BCM_HighBeam 0 "Off" 1 "On" ;
VAL_ 200 RadarTrack RadarMode 0 "Standby" 1 "Normal" 2 "Adaptive" 3 "Fault" ;

CM_ BO_ 100 "BCM Status Message - Contains door lock, lighting and vehicle status signals";
CM_ BO_ 200 "Engine Data Message - Contains speed, temperature and load signals";
CM_ SG_ 100 BCM_BatteryVoltage "Battery voltage in 0.01V resolution";
CM_ SG_ 100 BCM_Odometer "Multiplexer: 0=TripA, 1=TripB, 2=FuelLevel";
